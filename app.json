{
  "expo": {
    "name": "MyKeyz Care",
    "slug": "mykeyz-care",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mykeyzcare",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.mykeyz.care",
      "buildNumber": "4",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "MyKeyz Care lets providers add real job photos to their profile.",
        "NSPhotoLibraryUsageDescription": "MyKeyz Care lets providers upload before and after work photos.",
        "NSMicrophoneUsageDescription": "MyKeyz Care lets providers dictate quotes in their language.",
        "NSSpeechRecognitionUsageDescription": "MyKeyz Care uses speech recognition to turn spoken prices into quotes."
      }
    },
    "android": {
      "package": "com.mykeyz.care",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "MyKeyz Care lets providers upload before and after work photos.",
          "cameraPermission": "MyKeyz Care lets providers add real job photos to their profile."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "MyKeyz Care lets providers dictate quotes in their language.",
          "speechRecognitionPermission": "MyKeyz Care uses speech recognition to turn spoken prices into quotes.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-secure-store",
      "expo-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ccfaaf4-45c6-43c4-91fe-722f245821d6"
      }
    },
    "owner": "kbr_global",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9ccfaaf4-45c6-43c4-91fe-722f245821d6"
    }
  }
}
